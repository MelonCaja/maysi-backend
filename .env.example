# ── Base de datos ────────────────────────────────────────────────
# Railway lo provee automáticamente como DATABASE_URL.
# En local usa Docker:
DATABASE_URL=postgresql://postgres:maysi1234@localhost:5432/maysi

# ── Seguridad JWT ────────────────────────────────────────────────
# Genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_secreta_larga_y_aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Cloudinary (almacenamiento de archivos adjuntos) ─────────────
# Crea cuenta gratis en https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Dev local ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
